<?xml version="1.0" encoding="utf-8"?>
<!-- Android 12+: include the app's private files in cloud backup and device transfer. -->
<data-extraction-rules>
    <cloud-backup>
        <include domain="file" path="." />
    </cloud-backup>
    <device-transfer>
        <include domain="file" path="." />
    </device-transfer>
</data-extraction-rules>
