<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <!-- A book seen at a slight angle, with a combination-lock dial on the cover,
         reproducing the PageVault mark within the adaptive-icon safe zone. -->
    <group
        android:name="book"
        android:pivotX="52"
        android:pivotY="52"
        android:scaleX="0.82"
        android:scaleY="0.82"
        android:translateX="2"
        android:translateY="2">
        <!-- Pages (back) -->
        <path
            android:fillColor="#ECE0CB"
            android:pathData="M60,14 L86,16 L84,90 L58,88 Z" />
        <!-- Spine -->
        <path
            android:fillColor="#7A5A34"
            android:pathData="M54,14 L62,14 L60,88 L52,88 Z" />
        <!-- Cover (front) -->
        <path
            android:fillColor="#D4A843"
            android:pathData="M20,14 L56,14 L54,88 L18,88 Z" />
        <!-- Dial: dark disc -->
        <path
            android:fillColor="#201509"
            android:pathData="M22,48 a16,16 0 1,0 32,0 a16,16 0 1,0 -32,0 Z" />
        <!-- Dial: outer ring -->
        <path
            android:fillColor="#00000000"
            android:strokeColor="#E7BE5E"
            android:strokeWidth="1.3"
            android:pathData="M24.5,48 a13.5,13.5 0 1,0 27,0 a13.5,13.5 0 1,0 -27,0" />
        <!-- Dial: inner ring -->
        <path
            android:fillColor="#00000000"
            android:strokeColor="#E7BE5E"
            android:strokeAlpha="0.5"
            android:strokeWidth="0.9"
            android:pathData="M29,48 a9,9 0 1,0 18,0 a9,9 0 1,0 -18,0" />
        <!-- Dial: centre -->
        <path
            android:fillColor="#E7BE5E"
            android:pathData="M34,48 a4,4 0 1,0 8,0 a4,4 0 1,0 -8,0 Z" />
        <!-- Dial: pointer -->
        <path
            android:strokeColor="#E7BE5E"
            android:strokeWidth="1.8"
            android:strokeLineCap="round"
            android:pathData="M38,48 L38,35.5" />
    </group>
</vector>
