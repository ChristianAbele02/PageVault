<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/brand_bg">

    <WebView
        android:id="@+id/webview"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Splash overlay shown while embedded Python boots the local server. It
         fades out once the first page finishes loading. -->
    <LinearLayout
        android:id="@+id/splashOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/brand_bg"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp">

        <ImageView
            android:id="@+id/splashLogo"
            android:layout_width="148dp"
            android:layout_height="148dp"
            android:contentDescription="@string/app_name"
            android:src="@drawable/ic_launcher_foreground" />

        <TextView
            android:id="@+id/splashStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/splash_starting"
            android:textColor="@color/brand_text_dim"
            android:textSize="15sp" />

        <ProgressBar
            android:id="@+id/splashProgress"
            style="?android:attr/progressBarStyle"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginTop="24dp"
            android:indeterminateTint="@color/brand_gold" />

        <Button
            android:id="@+id/splashRetry"
            style="?android:attr/buttonStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:backgroundTint="@color/brand_surface"
            android:text="@string/splash_retry"
            android:textColor="@color/brand_text"
            android:visibility="gone" />
    </LinearLayout>
</FrameLayout>
