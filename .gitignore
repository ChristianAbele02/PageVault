# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ── Virtual environments ───────────────────────────────────────────────────────
.venv/
venv/
.pagevault/
env/
ENV/
env.bak/
venv.bak/
.python-version

# ── Database ───────────────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
# Keep the schema definition if you have one
!schema.sql

# ── PageVault runtime state (written when running from a source checkout) ──────
# The desktop/web app persists these next to the code when not frozen. They hold
# local secrets and user data — never commit them.
secret_key
admin_password.txt
book_files/
covers/

# ── Testing & coverage ─────────────────────────────────────────────────────────
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.tox/
.nox/

# ── Linting ────────────────────────────────────────────────────────────────────
.ruff_cache/
.mypy_cache/

# ── Environment / secrets ──────────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.secret

# ── Code-signing material (NEVER commit private keys) ──────────────────────────
certs/
*.pfx
*.p12
*.cer
*.crt
*.key

# ── IDEs ──────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ── Docker ────────────────────────────────────────────────────────────────────
.dockerignore

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Desktop build artefacts ────────────────────────────────────────────────────
# PyInstaller writes to build/ and dist/ (already ignored above); the installer
# compiler writes here. The app icon (static/icon.ico, static/icon.png) is a
# committed asset and is intentionally not ignored.
installer_output/
