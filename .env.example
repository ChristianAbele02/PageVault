# PageVault — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Security ────────────────────────────────────────────────────────────────

# Flask secret key — MUST be set to a long random string in any networked deployment.
# If not set, a random key is generated per restart (sessions are invalidated on restart).
# Generate a key with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# Admin panel password.
# If not set, a random temporary password is generated and logged at startup each restart.
# Set this to a strong password before any networked deployment.
PAGEVAULT_ADMIN_PASSWORD=your-strong-password-here

# ── Database ─────────────────────────────────────────────────────────────────

# Path to the SQLite database file.
# Default: pagevault.db in the project root (or /data/pagevault.db in Docker).
PAGEVAULT_DB=pagevault.db

# ── Application ──────────────────────────────────────────────────────────────

# Runtime environment: development | testing | production
# Controls DEBUG flag and other environment-specific settings.
PAGEVAULT_ENV=development

# Flask debug mode (0 or 1). Do NOT enable in production.
FLASK_DEBUG=0

# Server port (default: 5000).
PORT=5000

# ── Logging ──────────────────────────────────────────────────────────────────

# Path to the rotating log file.
# Default: pagevault.log in the project root.
# Log rotation: 10 MB per file, 5 backups kept.
# PAGEVAULT_LOG_FILE=pagevault.log

# ── Mobile / Network access ───────────────────────────────────────────────────

# Override the host shown in the QR code for same-network mobile access.
# Useful when behind a reverse proxy, NAT, or custom domain.
# Example: PAGEVAULT_MOBILE_HOST=192.168.1.100:5000
# PAGEVAULT_MOBILE_HOST=

# ── Metadata lookup cache ─────────────────────────────────────────────────────

# How long ISBN lookup results are cached in seconds (default: 900 = 15 minutes).
# Set to 0 to disable caching.
# PAGEVAULT_LOOKUP_CACHE_TTL_SECONDS=900

# Maximum number of cached ISBN lookup results (default: 2000).
# PAGEVAULT_LOOKUP_CACHE_MAX_ITEMS=2000
