# PageVault — Environment Variables
# Copy to .env and fill in your values. Never commit .env to version control.

# Flask secret key — change this to a long random string in any networked deployment
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# Path to the SQLite database file
# Default: pagevault.db in the project root
PAGEVAULT_DB=pagevault.db

# Flask environment
FLASK_ENV=development
